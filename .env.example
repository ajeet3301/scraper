# ════════════════════════════════════════════════════════
#  COPY THESE EXACT KEYS INTO VERCEL → Project → Settings → Environment Variables
#  All values are FREE to get. Instructions: README.md
# ════════════════════════════════════════════════════════

# ── Supabase PostgreSQL (free at supabase.com) ─────────
# Settings → Database → Connection string → URI  (Transaction mode, port 6543)
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Settings → Database → Connection string → URI  (Direct, port 5432) - for migrations
# If your Supabase plan only gives you one connection string, just use the
# same value for both DATABASE_URL and DIRECT_URL.
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ── NextAuth ────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="your_random_64_char_hex_string_here"

# Your Vercel app URL (after first deploy, update this)
NEXTAUTH_URL="https://your-app.vercel.app"

# ── GitHub OAuth (free at github.com/settings/applications/new) ──
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── Google OAuth (free at console.cloud.google.com) ────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Firecrawl (optional premium scraper - firecrawl.dev) ──
FIRECRAWL_API_KEY=""
